# Copiar a .env y completar. NO committear el .env con credenciales reales.

# Postgres central — Railway lo provee via DATABASE_URL
DATABASE_URL=postgresql://user:pass@host:port/dbname

# Secreto para firmar tokens de sesión. MISMO en todos los sistemas de la suite.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
KUBOC_CORE_SECRET=genera-un-secreto-largo-aqui

# Opcional: nombre de la cookie cross-sistema (default: kuboc_session)
# KUBOC_COOKIE_NAME=kuboc_session

# Opcional: TTL de sesión en horas (default: 12)
# KUBOC_SESSION_TTL_HOURS=12
